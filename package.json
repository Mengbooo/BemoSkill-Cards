{
  "name": "social-card-skill",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "scripts": {
    "render:xhs-dark": "node scripts/render-html-assets.mjs --html assets/templates/xhs-dark.html --out output/xhs-dark --selector .card --viewport 1200x1600 --background '#000'",
    "render:xhs-light": "node scripts/render-html-assets.mjs --html assets/templates/xhs-light.html --out output/xhs-light --selector .card --viewport 1200x1600 --background '#f4efe7'",
    "render:platform": "node scripts/render-html-assets.mjs --html assets/templates/platform-covers.html --out output/platform-covers --selector .cover-card --group-attrs data-style,data-platform --viewport 1600x900 --background '#111'",
    "overview:platform": "node scripts/make-overview.mjs --root output/platform-covers --out output/platform-covers/overview.png --thumb 300x128 --cols 5",
    "overview:xhs-dark": "node scripts/make-overview.mjs --root output/xhs-dark --out output/xhs-dark/overview.png --thumb 270x360 --cols 5",
    "overview:xhs-light": "node scripts/make-overview.mjs --root output/xhs-light --out output/xhs-light/overview.png --thumb 270x360 --cols 5"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "sharp": "^0.34.0"
  }
}
